# Nguon job: keyword search = GraphQL (FlareSolverr + .auth), khong con scrape HTML trong scanner.
# RSS: set UPWORK_FEED_URL, de trong UPWORK_SEARCH_KEYWORD (neu code RSS con dung)
UPWORK_SEARCH_KEYWORD=spring boot
UPWORK_FEED_URL=

UPWORK_IMPERSONATE=chrome120

# FlareSolverr: khi chay crawler NGOAI Docker — vd. http://localhost:8191
# Khi dung docker-compose, crawler tu dong dung http://flaresolverr:8191 (khong can sua .env)
FLARESOLVERR_URL=http://localhost:8191
# Timeout ms cho FlareSolverr (warm + challenge). GraphQL + login dung chung.
# FLARESOLVERR_TIMEOUT_MS=120000

# --- Upwork: GraphQL + login (Playwright) + thu muc .auth ---
# Can: pip install playwright && playwright install chromium
# Thieu storage_state.json + co UPWORK_EMAIL/PASSWORD => scanner tu chay login lan dau.
UPWORK_FETCH_MODE=auto
# UPWORK_AUTH_DIR=                # Docker compose: mac dinh /app/.auth (volume crawler_auth — persist)
# UPWORK_AUTO_LOGIN — tuy chon; neu thieu .auth van login neu co email/password
UPWORK_AUTO_LOGIN=0
UPWORK_EMAIL=
UPWORK_PASSWORD=
UPWORK_LOGIN_FORM=1
UPWORK_GRAPHQL_403_MAX_RETRIES=3
UPWORK_GRAPHQL_SORT=recency+desc
UPWORK_GRAPHQL_PAGE_SIZE=50
UPWORK_GRAPHQL_MINIMAL=0
# UPWORK_GRAPHQL_DEBUG=1   # in full body JSON GraphQL (log dai)
# UPWORK_GRAPHQL_BODY=            # ghi de file body JSON (mac dinh: upwork/data/userJobSearch_body.json)
# UPWORK_WARM_URL=
# UPWORK_GRAPHQL_REFERER=

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# De trong, * hoac all = gui job cho moi user da /start bot. So cu the = them chat do + nguoi /start
TELEGRAM_CHAT_ID=*

# Neu api.telegram.org timeout trong Docker: TELEGRAM_HTTP_TIMEOUT=60 hoac HTTPS_PROXY (requests doc lap)
# TELEGRAM_HTTP_TIMEOUT=45
# TELEGRAM_HTTP_RETRIES=3
# HTTPS_PROXY=http://host.docker.internal:7890

# Tom tat job: can it nhat mot — NINEROUTER (uu tien), OPENROUTER, hoac GEMINI
GEMINI_API_KEY=

# 9Router (OpenAI-compatible). Docker compose: crawler da set NINEROUTER_*; chay local thi dat duoi day
# Base chi can host:port — client tu dong goi /api/v1/chat/completions
NINEROUTER_BASE_URL=http://localhost:20128
NINEROUTER_API_KEY=sk_9router
NINEROUTER_MODEL=cc/claude-opus-4-6

# 9Router container (docker-compose `ninerouter`) — tuy chon; ghi de mac dinh trong compose
# NINEROUTER_JWT_SECRET=
# NINEROUTER_INITIAL_PASSWORD=
# NINEROUTER_APP_BASE_URL=http://localhost:20128
# NINEROUTER_NEXT_PUBLIC_BASE_URL=http://localhost:20128

# Optional
POLL_INTERVAL_SECONDS=300
SEEN_STORE_PATH=.seen_jobs.json
TELEGRAM_SUBSCRIBERS_STORE_PATH=.telegram_subscribers.json
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Logging detail
# UPWORK_LOG_DIR=./logs
# UPWORK_LOG_LEVEL=INFO
# UPWORK_LOG_FILE=upwork_scanner.log
