# Copy -> login.env và điền giá trị (login.env đã .gitignore).
#   cp login.env.example login.env
#
# Chạy:
#   python3 login_via_flaresolverr.py
# Script tự đọc login.env cùng thư mục (không ghi đè biến đã export sẵn).
# Hoặc: set -a && source login.env && set +a && python3 login_via_flaresolverr.py

# Bắt buộc
UPWORK_EMAIL=your@email.com
UPWORK_PASSWORD=REPLACE_ME

# Tuỳ chọn — iovation / forter: script trích từ trang; nếu vẫn trống, copy từ DevTools →
#   Network → POST .../login (bước password) → Payload → login.iovation (chuỗi rất dài)
# UPWORK_IOVATION=
# UPWORK_FORTER_TOKEN=

# Sau login: lấy thêm token (giống capture 0019 / 0046)
UPWORK_FETCH_VISITOR_GQL=1
UPWORK_FETCH_SUBORDINATE=1

# Playwright: 1 = headless (mặc định), 0 = mở cửa sổ Chromium (debug)
# UPWORK_PLAYWRIGHT_HEADLESS=0
# Kích thước cửa sổ (fetch trong trang sau goto — cùng cookie với phiên)
# UPWORK_PLAYWRIGHT_VIEWPORT=1280x900
# page.goto: domcontentloaded | load | networkidle | commit (mặc định networkidle; đổi nếu treo lâu)
# UPWORK_PLAYWRIGHT_GOTO_WAIT=domcontentloaded

# Debug — ghi log chi tiết ra login_debug_YYYYMMDD_HHMMSS.log (đã .gitignore)
# UPWORK_LOGIN_DEBUG=0
# UPWORK_LOGIN_DEBUG_LOG=/tmp/upwork_login_debug.log
# In thêm từng bước ra console (status, URL, tóm tắt login JSON); 0 = tắt
# UPWORK_LOGIN_VERBOSE=1

# Đăng nhập bằng điền form trên trang (Playwright fill/click) thay vì fetch API — iovation do trình duyệt gửi
# UPWORK_LOGIN_FORM=1
# UPWORK_LOGIN_FORM_TIMEOUT_MS=90000
# UPWORK_LOGIN_FORM_SUCCESS_GLOB=**/nx/**

# Tuỳ chọn khác
# UPWORK_SUBORDINATE_CLIENT_ID=ad40656599b41c597ebc81ca2e09a677
# UPWORK_LOGIN_WARM_URL=https://www.upwork.com/ab/account-security/login
# FLARESOLVERR_TIMEOUT_MS=120000
# FLARESOLVERR_URL=http://localhost:8191
