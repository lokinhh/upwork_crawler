# Copy -> login.env and fill in the value (login.env has .gitignore).
#   cp login.env.example login.env
#
# Run:
#   python3 login_via_flaresolverr.py
# The script automatically reads login.env from the same directory (does not overwrite exported variables).
# Or: set -a && source login.env && set +a && python3 login_via_flaresolverr.py

# Obligatory
UPWORK_EMAIL=your@email.com
UPWORK_PASSWORD=REPLACE_ME

# Options — iovation / forter: script extracted from page; If it's still blank, copy it from DevTools →
# Network → POST .../login (password step) → Payload → login.iovation (very long string)
# UPWORK_IOVATION=
# UPWORK_FORTER_TOKEN=

# After login: get more tokens (same as capture 0019 / 0046)
UPWORK_FETCH_VISITOR_GQL=1
UPWORK_FETCH_SUBORDINATE=1

# Playwright: 1 = headless (default), 0 = open Chromium window (debug)
# UPWORK_PLAYWRIGHT_HEADLESS=0
# Window size (fetch in page after goto — same cookie as session)
# UPWORK_PLAYWRIGHT_VIEWPORT=1280x900
# page.goto: domcontentloaded | load | networkidle | commit (default networkidle; change if hanging too long)
# UPWORK_PLAYWRIGHT_GOTO_WAIT=domcontentloaded

# Debug — write detailed log to login_debug_YYYYMMDD_HHMMSS.log (with .gitignore)
# UPWORK_LOGIN_DEBUG=0
# UPWORK_LOGIN_DEBUG_LOG=/tmp/upwork_login_debug.log
# Print more steps to the console (status, URL, JSON login summary); 0 = off
# UPWORK_LOGIN_VERBOSE=1

# Login by filling out the form on the page (Playwright fill/click) instead of fetch API — iovation sent by the browser
# UPWORK_LOGIN_FORM=1
# UPWORK_LOGIN_FORM_TIMEOUT_MS=90000
# UPWORK_LOGIN_FORM_SUCCESS_GLOB=**/nx/**

# Other options
# UPWORK_SUBORDINATE_CLIENT_ID=ad40656599b41c597ebc81ca2e09a677
# UPWORK_LOGIN_WARM_URL=https://www.upwork.com/ab/account-security/login
# FLARESOLVERR_TIMEOUT_MS=120000
# FLARESOLVERR_URL=http://localhost:8191
