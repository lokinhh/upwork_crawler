# Copy -> curl.env and fill in the value (curl.env has .gitignore).
# Retrieved from DevTools → Network → request userJobSearch → Headers.

UPWORK_AUTHORIZATION='Bearer oauth2v2_int_REPLACE_ME'
UPWORK_COOKIE='REPLACE_ME'
UPWORK_TENANT_ID='REPLACE_ME'

# Options:
# UPWORK_REFERER='https://www.upwork.com/nx/search/jobs/?q=spring%20boot&page=1'
# UPWORK_OUT='./last_response.json'
# UPWORK_VERBOSE=1
UPWORK_LOGIN_DEBUG=1